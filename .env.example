# ─────────────────────────────────────────────────────────────
# Kushal Portfolio — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to `.env.local` (which is gitignored) and fill in.

# AI Playground (powered by Groq — free tier, no card required)
# Get your key at: https://console.groq.com/keys
# Free tier: 30 req/min, plenty for a portfolio site
GROQ_API_KEY=your_groq_api_key_here

# Optional: override the default model.
# Recommended: llama-3.3-70b-versatile (best quality, free)
# Faster:      llama-3.1-8b-instant
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: rate limit per IP per hour (defaults to 30 if unset)
PLAYGROUND_RATE_LIMIT=30
